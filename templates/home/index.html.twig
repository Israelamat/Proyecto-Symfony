{% extends 'base.html.twig' %}

{% block title %}Inicio | Tienda de Videojuegos
{% endblock %}

{% block body %}

	<div class="section">
		<div class="container">
			<div class="row">

				<div class="col-md-12">
					<div class="section-title">
						<h3 class="title">Juegos en venta</h3>

					</div>
				</div>
			</div>

			<div class="row filters-row mt-3 mb-4">
				<form method="get" action="{{ path('home') }}" class="row g-2">

					<div class="col-md-2">
						<label class="filter-label">Género</label>
						<select name="genre" class="input-select form-select" style="max-width: 110%;">
							<option value="">Todos los géneros</option>
							{% for genre in genres %}
								<option value="{{ genre.id }}" {% if app.request.get('genre') == genre.id %} selected {% endif %}>
									{{ genre.name }}
								</option>
							{% endfor %}
						</select>
					</div>

					<div class="col-md-2">
						<label class="filter-label">Desde</label>
						<input type="date" name="date_from" class="input form-control" value="{{ app.request.get('date_from') }}">
					</div>

					<div class="col-md-2">
						<label class="filter-label">Hasta</label>
						<input type="date" name="date_to" class="input form-control" value="{{ app.request.get('date_to') }}">
					</div>

					<div class="col-md-3">
						<label class="filter-label">Buscar juego</label>
						<input type="text" name="q" class="input form-control" placeholder="Título o descripción" value="{{ app.request.get('q') }}">
					</div>

					<div class="col-md-2">
						<button class="btn btn-danger" style="margin-top: 16px; width: 100%; font-size: 18px;">
							<i class="fa fa-search"></i>
							Buscar
						</button>
					</div>

				</form>
			</div>


			<div class="row" style="margin-bottom: 50px;">

				{% for game in games %}
					<div class="col-md-4">
						<div class="product">

							<div class="product-img">
								<img class="game-grid-img" src="{{ game.image ? asset('uploads/games/' ~ game.image) : asset('img/default-game.jpg') }}" alt="{{ game.title }}">
								<div class="product-label">
									<span class="sale">
										{{ game.createdAt|date('d/m') }}
									</span>
								</div>
							</div>

							<div class="product-body">
								<p class="product-category">
									Vendido por
									<span class="badge">{{ game.user.name }}</span>
								</p>

								<h3 class="product-name">
									<a href="{{ path('game_show', {id: game.id}) }}">
										{{ game.title }}
									</a>
								</h3>

								<h4 class="product-price">
									€{{ game.price|number_format(2, '.', ',') }}
								</h4>

								<div class="product-btns">
									<a href="{{ path('game_show', {id: game.id}) }}" class="quick-view">
										<i class="fa fa-eye"></i>
										<span class="tooltipp">Ver más</span>
									</a>
								</div>
							</div>

							{% if app.user and app.user == game.user %}
								<div class="add-to-cart">
									<a href="{{ path('game_edit', {id: game.id}) }}" class="add-to-cart-btn">
										<i class="fa fa-edit"></i>
										editar juego
									</a>
								</div>
							{% endif %}

						</div>
					</div>

				{% else %}
					<div class="col-md-12">
						<div class="alert alert-info text-center">
							{% set hasFilters = app.request.get('q') or app.request.get('genre') or app.request.get('date_from') or app.request.get('date_to') %}

							{% if hasFilters %}
								No hay resultados para los filtros aplicados.
								<br>
								<a href="{{ path('home') }}" class="btn btn-secondary mt-3">
									<i class="fa fa-undo"></i>
									Restablecer filtros
								</a>
							{% else %}
								No hay juegos disponibles ahora mismo.
							{% endif %}
						</div>
					</div>
				{% endfor %}


			</div>


		</div>
	</div>
{% endblock %}
