{% extends 'base.html.twig' %}

{% block title %}Crear evento
{% endblock %}

{% block body %}
	<div class="section">
		<div class="container">
			<h3>Crear nuevo evento</h3>
			<div class="row">
				<div class="col-md-8 col-md-offset-2">
					{{ form_start(form) }}

					<div class="form-group">
						{{ form_label(form.name) }}
						{{ form_widget(form.name, {'attr': {'class': 'form-control input'}}) }}
						{{ form_errors(form.name) }}
					</div>

					<div class="form-group">
						{{ form_label(form.description) }}
						{{ form_widget(form.description, {'attr': {'class': 'form-control input'}}) }}
						{{ form_errors(form.description) }}
					</div>

					<div class="form-group">
						{{ form_label(form.eventDate) }}
						{{ form_widget(form.eventDate, {'attr': {'class': 'form-control input'}}) }}
						{{ form_errors(form.eventDate) }}
					</div>

					<div class="form-group">
						<label>{{ form_label(form.games) }}</label>

						<div class="row">
							{% for game in form.games %}
								<div class="col-md-4">
									<div class="checkbox">
										<label>
											{{ form_widget(game) }}
											{{ game.vars.label }}
										</label>
									</div>
								</div>
							{% endfor %}
						</div>

						{{ form_errors(form.games) }}

						<button class="btn btn-danger mt-3">
							Crear evento
						</button>

						{{ form_end(form) }}
					</div>
				</div>


			</div>
		</div>
	</div>
{% endblock %}
