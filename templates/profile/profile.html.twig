{% extends 'base.html.twig' %}

{% block title %}Mi perfil | Tienda de Videojuegos
{% endblock %}

{% set activeTab = app.request.query.get('tab') ?? 'datos' %}

{% block body %}
	<div class="section">
		<div class="container">

			<div class="section-title mb-4">
				<h3 class="title">Mi perfil</h3>
			</div>

			<div class="row">
				<div class="col-md-10 col-md-offset-1">

					<div class="panel panel-default">
						<div class="panel-body">


							<ul class="nav nav-tabs">
								<li class="{{ activeTab == 'datos' ? 'active' }}">
									<a href="#datos" data-toggle="tab">Datos del usuario</a>
								</li>
								<li class="{{ activeTab == 'password' ? 'active' }}">
									<a href="#password" data-toggle="tab">Cambiar contraseña</a>
								</li>
								<li class="{{ activeTab == 'avatar' ? 'active' }}">
									<a href="#avatar" data-toggle="tab">Imagen de perfil</a>
								</li>
							</ul>


							<div class="tab-content" style="margin-top:20px">

								<div class="tab-pane fade {{ activeTab == 'datos' ? 'in active' }}" id="datos">

									<div class="row user-profile-box">

										<div class="col-md-4 text-center">
											<div class="avatar-wrapper">
												<img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar" class="img-circle user-avatar">
											</div>
										</div>

										<div class="col-md-8">
											<h2 class="user-name">{{ user.name }}</h2>

											<p class="user-email">
												<i class="fa fa-envelope"></i>
												{{ user.email }}
											</p>

											{% if user.roles is defined and 'ROLE_ADMIN' in user.roles %}
												<p class="user-meta">
													<i class="fa fa-shield"></i>
													Administrador
												</p>
											{% endif %}

											<hr>

											<p class="user-meta">
												<i class="fa fa-user"></i>
												Usuario registrado
											</p>
										</div>

									</div>

								</div>


								<div class="tab-pane fade {{ activeTab == 'password' ? 'in active' }}" id="password">

									{% for label, messages in app.flashes %}
										{% for message in messages %}
											{% set type = label == 'error' ? 'danger' : 'success' %}
											<div class="alert alert-{{ type }}">{{ message }}</div>
										{% endfor %}
									{% endfor %}

									{{ form_start(passwordForm, {
										'method': 'POST',
										'action': path('profile_password')
									}) }}

									<div class="form-group">
										{{ form_label(passwordForm.currentPassword) }}
										{{ form_widget(passwordForm.currentPassword, {'attr': {'class': 'input form-control'}}) }}
										{{ form_errors(passwordForm.currentPassword) }}
									</div>

									<div class="form-group">
										{{ form_label(passwordForm.newPassword) }}
										{{ form_widget(passwordForm.newPassword, {'attr': {'class': 'input form-control'}}) }}
										{{ form_errors(passwordForm.newPassword) }}
									</div>

									<div class="form-group">
										{{ form_label(passwordForm.repeatPassword) }}
										{{ form_widget(passwordForm.repeatPassword, {'attr': {'class': 'input form-control'}}) }}
										{{ form_errors(passwordForm.repeatPassword) }}
									</div>

									<button class="btn btn-danger">
										<i class="fa fa-lock"></i>
										Cambiar contraseña
									</button>

									{{ form_end(passwordForm) }}

								</div>

								<div class="tab-pane fade {{ activeTab == 'avatar' ? 'in active' }}" id="avatar">

									{{ form_start(avatarForm, {
                                        'method': 'POST',
                                        'action': path('profile_avatar'),
                                        'attr': {'enctype': 'multipart/form-data'
                                    }}) }}

									<div class="mb-3 text-center">
										<img id="avatar-preview" src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar" width="100" height="100" style="border-radius:50%;">
									</div>

									{% for label, messages in app.flashes %}
										{% for message in messages %}
											{% set type = label == 'error' ? 'danger' : 'success' %}
											<div class="alert alert-{{ type }}">{{ message }}</div>
										{% endfor %}
									{% endfor %}


									<div class="form-group">
										{{ form_label(avatarForm.avatar) }}
										{{ form_widget(avatarForm.avatar, {'attr': {'class': 'form-control'}}) }}
										<!-- {{ form_errors(avatarForm.avatar) }} -->

										{% if avatarForm.avatar.vars.errors|length > 0 %}
											<div class="alert alert-danger" style="margin-top:10px;">
												<ul style="margin:0; padding-left:20px;">
													{% for error in avatarForm.avatar.vars.errors %}
														<li>
															<strong>Error:</strong>
															{{ error.message }}</li>
													{% endfor %}
												</ul>
											</div>
										{% endif %}

									</div>

									<div class="text-center" style="margin-top:15px;">
										<button class="btn btn-danger">
											<i class="fa fa-upload"></i>
											Subir imagen
										</button>
									</div>

									{{ form_end(avatarForm) }}

									<script>
										document.getElementById('avatar_form_avatar').addEventListener('change', function (event) {
console.log(this.files);
const [file] = this.files;
if (file) {
const preview = document.getElementById('avatar-preview');
preview.src = URL.createObjectURL(file);
}
});
									</script>
								</div>


							</div>

						</div>
					</div>

				</div>
			</div>

		</div>
	</div>
{% endblock %}
