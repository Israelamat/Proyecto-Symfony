{% extends 'base.html.twig' %}

{% block title %}{{ game.title }} | Tienda de Videojuegos{% endblock %}

{% block body %}
<div class="section">
    <div class="container">
        <div class="row">

            <div class="col-md-6">
                <div id="product-main-img">
                    <img src="{{ asset('uploads/games/' ~ game.image) }}" 
					alt="{{ game.title }}" class="img-responsive">
                </div>
            </div>

            <div class="col-md-6">
                <div class="product-details">

                    <h2 class="product-name">{{ game.title }}</h2>

                    <div>
                        <a class="review-link">
                            Publicado por
                            <span class="badge bg-secondary">
                                {{ game.user.name }}
                            </span>
                        </a>
                    </div>

                    <div>
                        <h3 class="product-price">€{{ game.price|number_format(2, '.', ',') }}</h3>
                    </div>

                    <ul class="product-links">
                        <li>Géneros:</li>
                        {% for genre in game.genres %}
                            <li>
                                <span class="badge bg-dark">{{ genre.name }}</span>
                            </li>
                        {% endfor %}
                    </ul>

                    <ul class="product-links">
                        <li>Publicado:</li>
                        <li>{{ game.createdAt|date('d/m/Y') }}</li>
                    </ul>

                    <p style="margin-top: 10px;">
                        {{ game.description }}
                    </p>

                    {% if isOwner %}
                        <div class="mt-4">
                            <a href="" class="btn btn-warning me-2">
                                <i class="fa fa-edit"></i> Editar
                            </a>

							<a href="{{ path('game_delete', {id: game.id}) }}" 
								class="btn btn-sm btn-danger" 
								onclick="return confirm('¿Seguro que quieres eliminar el juego {{ game.title }}? Esta acción no se puede deshacer.');">
								<i class="fa fa-trash"></i>
								Eliminar
							</a>
                        </div>
                    {% else %}
                        <div class="add-to-cart mt-4">
                            <button class="add-to-cart-btn">
                                <i class="fa fa-shopping-cart"></i>
                                Comprar juego
                            </button>
                        </div>
                    {% endif %}

                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
