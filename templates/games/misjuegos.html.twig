{% extends 'base.html.twig' %}

{% block title %}Mis juegos | Tienda de Videojuegos
{% endblock %}

{% block body %}
	<div class="section">
		<div class="container">

			<div class="section-title">
				<div class="row">
					<div class="col-md-8">
						<h3 class="title">Mis juegos añadidos</h3>
					</div>
					<div class="col-md-4 text-right">
						<a href="{{ path('game_new') }}" class="btn btn-danger" style="font-size: 14px;font-weight: bold;">
							<i class="fa fa-plus"></i>
							Añadir nuevo juego
						</a>
					</div>
				</div>
			</div>

			{% for label, messages in app.flashes %}
				{% for message in messages %}
					<div class="alert alert-{{ label }}">{{ message }}</div>
				{% endfor %}
			{% endfor %}


			<div class="table-responsive">
				<table class="table table-striped table-hover table-bordered align-middle text-center">
					<thead class="table-dark">
						<tr>
							<th class="text-center">Título</th>
							<th class="text-center">Fecha</th>
							<th class="text-center">Precio</th>
							<th class="text-center">Géneros</th>
							<th class="text-center">Acciones</th>
						</tr>
					</thead>
					<tbody>
						{% for game in games %}
							<tr>
								<td>{{ game.title }}</td>
								<td>{{ game.createdAt|date('d/m/Y') }}</td>
								<td>€{{ game.price|number_format(2, ',', '.') }}</td>
								<td>
									{% for genre in game.genres %}
										<span class="badge bg-secondary me-1">{{ genre.name }}</span>
									{% endfor %}
								</td>
								<td>
									<a href="{{ path('game_show', {id: game.id}) }}" class="btn btn-sm btn-info me-1">
										<i class="fa fa-eye"></i>
										Ver
									</a>
									<button class="btn btn-sm btn-warning me-1">
										<i class="fa fa-edit"></i>
										Editar
									</button>
									<a href="{{ path('game_delete', {id: game.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('¿Seguro que quieres eliminar el juego {{ game.title }}? Esta acción no se puede deshacer.');">
										<i class="fa fa-trash"></i>
										Eliminar
									</a>
								</td>
							</tr>
						{% else %}
							<tr>
								<td colspan="5" class="text-center">No has añadido juegos todavía</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			</div>

		</div>
	</div>
{% endblock %}
