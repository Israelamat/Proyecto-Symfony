{% extends 'base.html.twig' %}

{% block title %}Mis juegos | Tienda de Videojuegos{% endblock %}

{% block body %}
<div class="section">
    <div class="container">

        <div class="section-title mb-4">
            <h3 class="title">Mis juegos añadidos</h3>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Título</th>
                        <th class="text-center">Fecha</th>
                        <th class="text-center">Precio</th>
                        <th class="text-center">Géneros</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for game in games %}
                        <tr>
                            <td>{{ game.title }}</td>
                            <td>{{ game.date }}</td>
                            <td>€{{ game.price }}</td>
                            <td>
                                {% for genre in game.genres %}
                                    <span class="badge bg-secondary me-1">{{ genre }}</span>
                                {% endfor %}
                            </td>
                            <td>
                                <button class="btn btn-sm btn-info me-1">
                                    <i class="fa fa-eye"></i> Ver
                                </button>
                                <button class="btn btn-sm btn-warning me-1">
                                    <i class="fa fa-edit"></i> Editar
                                </button>
                                <button class="btn btn-sm btn-danger">
                                    <i class="fa fa-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center">No has añadido juegos todavía</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
</div>
{% endblock %}
