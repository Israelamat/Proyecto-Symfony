{% extends 'base.html.twig' %}

{% block title %}Usuarios | Admin{% endblock %}

{% block body %}
<div class="section">
    <div class="container">

        <!-- Filtros -->
        <div class="row mb-3 align-items-center">
            <div class="col-md-3">
                <select id="filter-type" class="form-select input-select">
                    <option value="">Todos los tipos</option>
                    <option value="normal">Normal</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
            <div class="col-md-3">
                <div class="search-users d-flex"> 
                    <input type="text" id="search-name" class="form-control input" placeholder="Buscar por nombre">
                    <button id="search-button" class="btn btn-primary">Buscar</button>
                </div>

            </div>
        </div>
        <br>
        <!-- Tabla de usuarios -->
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered align-middle text-center" id="users-table">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">Nombre</th>
                        <th class="text-center">Email</th>
                        <th class="text-center">Tipo</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td>{{ user.name }}</td>
                        <td>{{ user.email }}</td>
                        <td>
                            <span class="badge {{ user.type == 'admin' ? 'bg-danger' : 'bg-secondary' }}">
                                {{ user.type|capitalize }}
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info me-1">Cambiar tipo</button>
                            <button class="btn btn-sm btn-danger">Eliminar</button>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-center">No hay usuarios</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style>
/* Botones rojos según plantilla D10024 */
.btn-danger {
    background-color: #D10024;
    border-color: #D10024;
    color: #fff;
}

.btn-danger:hover {
    background-color: #ef233c;
    border-color: #ef233c;
}

.btn-outline-danger {
    color: #D10024;
    border-color: #D10024;
}

.btn-outline-danger:hover {
    background-color: #D10024;
    color: #fff;
}

/* Tabla */
#users-table th, #users-table td {
    vertical-align: middle;
}

#users-table tbody tr:hover {
    background-color: rgba(209, 0, 36, 0.1);
}
</style>
{% endblock %}
