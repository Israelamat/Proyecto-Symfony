{% extends 'base.html.twig' %}

{% block title %}Formulario de registro | Tienda de Videojuegos{% endblock %}

{% block body %}

<div class="section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-md-offset-3">
                <div class="login-form">
                    <div class="section-title text-center mb-4">
                        <h3 class="title">Registrarse</h3>
                    </div>
                    <form method="post">
                        <div class="form-group mb-3">
                            <label for="name">Nombre completo</label>
                            <input type="text" id="name" name="name" class="input form-control" required autofocus>  
                        </div>
                        <div class="form-group mb-3">
                            <label for="email">Correo electrónico</label>
                            <input type="email" id="email" name="email" class="input form-control" required autofocus>  
                        </div>
                        <div class="form-group mb-4">
                            <label for="password">Contraseña</label>
                            <input type="password" id="password" name="password" class="input form-control" required>
                        </div>

                        <!-- Botón centrado -->
                        <div class="text-center mb-3">
                            <button type="submit" class="auth-btn">Iniciar sesión</button>
                        </div>

                        <!-- Enlace a registro -->
                        <div class="text-center">
                            <small>¿No tienes cuenta? <a href="">Regístrate aquí</a></small>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
